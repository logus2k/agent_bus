# Agent Bus — configuration (copy to .env; all values have safe defaults in config.py)

# --- Valkey connection ---
# Inside the compose network the host is the service name; from the host it is 127.0.0.1.
VALKEY_HOST=valkey-bus
VALKEY_PORT=6379

# --- Discovery ---
# Set of currently-active initiator stream ids (actors poll this each cycle).
ACTIVE_STREAMS_KEY=streams:active
# Prefix applied to initiator ids to form the stream key: stream:<initiator_id>
STREAM_PREFIX=stream:
# Dead Letter Queue stream.
DLQ_STREAM=stream:dlq

# --- Actor consume loop ---
# Poll interval (ms) for the non-blocking XREADGROUP loop across active streams.
ACTOR_POLL_MS=100

# --- Workflow lifecycle ---
# Optional runaway backstop. 0 = unlimited (no automatic step cap; the default).
# A positive value force-terminates a workflow once its sid reaches that step count.
# Termination is otherwise explicit (terminate command / actor) or natural (flow goes quiet).
MAX_THRESHOLD=0

# Echo demo only: true = agent/tool ping-pong forever (synthetic outlier for testing
# iteration-visibility + the terminate command); false = finite request->thought->result->terminated.
ECHO_LOOP=false

# --- Reaper (XAUTOCLAIM) ---
# Messages idle longer than this (ms) are reclaimed from dead consumers.
REAPER_MIN_IDLE_MS=30000
# How often (seconds) the reaper sweeps active streams.
REAPER_INTERVAL_S=15

# --- Stream cleanup ---
# Idle TTL (seconds) safety net for streams whose initiator vanished without a clean disconnect.
STREAM_TTL_S=3600

# --- Gateway (Socket.IO) ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=6815

# --- Logging ---
LOG_LEVEL=INFO
